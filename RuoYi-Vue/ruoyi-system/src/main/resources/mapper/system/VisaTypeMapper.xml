<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.visa.mapper.VisaTypeMapper">
    
    <resultMap type="VisaType" id="VisaTypeResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="code"    column="code"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectVisaTypeVo">
        select id, name, code, sort, status from visa_type
    </sql>

    <select id="selectVisaTypeList" parameterType="VisaType" resultMap="VisaTypeResult">
        <include refid="selectVisaTypeVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectVisaTypeById" parameterType="Long" resultMap="VisaTypeResult">
        <include refid="selectVisaTypeVo"/>
        where id = #{id}
    </select>

    <insert id="insertVisaType" parameterType="VisaType" useGeneratedKeys="true" keyProperty="id">
        insert into visa_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="code != null">code,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="code != null">#{code},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
         </trim>
    </insert>

    <update id="updateVisaType" parameterType="VisaType">
        update visa_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where id = #{id}
    </update>
    <update id="updateTypeStatus">
        update visa_type
        set status = #{status}
        where id = #{id}
    </update>

    <delete id="deleteVisaTypeById" parameterType="Long">
        delete from visa_type where id = #{id}
    </delete>

    <delete id="deleteVisaTypeByIds" parameterType="String">
        delete from visa_type where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>