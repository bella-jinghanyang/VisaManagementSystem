<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.visa.mapper.VisaOrderMapper">
    
    <resultMap type="VisaOrder" id="VisaOrderResult">
        <result property="id"    column="id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="customerId"    column="customer_id"    />
        <result property="productId"    column="product_id"    />
        <result property="quantity"    column="quantity"    />
        <result property="productSnapshot"    column="product_snapshot"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="status"    column="status"    />
        <result property="alipayNo"    column="alipay_no"    />
        <result property="payTime"    column="pay_time"    />
        <result property="submittedMaterials"    column="submitted_materials"    />
        <result property="auditRemark"    column="audit_remark"    />
        <result property="interviewTime"    column="interview_time"    />
        <result property="interviewLocation"    column="interview_location"    />
        <result property="interviewFile"    column="interview_file"    />
        <result property="interviewFeedback"    column="interview_feedback"    />
        <result property="visaResult"    column="visa_result"    />
        <result property="trackingNumber"    column="tracking_number"    />
        <result property="mailingAddress"    column="mailing_address"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="isInterviewRequired" column="is_interview_required" />
        <result property="interviewSlots" column="interview_slots" />
        <result property="supplementaryMaterials" column="supplementary_materials" />
        <result property="isCommented" column="is_commented" />
        <result property="commentId"    column="comment_id"    />
        <result property="commentRate"  column="comment_rate"  />
        <result property="commentText"  column="comment_text"  />
        <result property="adminReply"   column="admin_reply"   />
        <result property="additionalContent" column="additional_content" />
        <result property="additionalTime"    column="additional_time"    />
    </resultMap>

    <sql id="selectVisaOrderVo">
        select
            vo.id,
            vo.order_no,
            vo.customer_id,
            vo.product_id,
            vo.quantity,
            vo.product_snapshot,
            vo.total_amount,
            vo.status,
            vo.alipay_no,
            vo.pay_time,
            vo.submitted_materials,
            vo.audit_remark,
            vo.interview_time,
            vo.interview_location,
            vo.interview_file,
            vo.interview_feedback,
            vo.visa_result,
            vo.tracking_number,
            vo.mailing_address,
            vo.create_time,
            vo.update_time,
            vo.del_flag,
            vo.interview_slots,
            vo.supplementary_materials,
            vo.is_commented,
            vp.is_interview_required,
            vc.id as comment_id,
            vc.rating as comment_rate,
            vc.content as comment_text,
            vc.admin_reply as admin_reply,
            vc.additional_content as additional_content,
            vc.additional_time as additional_time
        from visa_order vo
                 left join visa_product vp on vo.product_id = vp.id
                 left join visa_comment vc on vo.id = vc.order_id
    </sql>

    <select id="selectVisaOrderList" parameterType="VisaOrder" resultMap="VisaOrderResult">
        <include refid="selectVisaOrderVo"/>
        <where>  
            <if test="orderNo != null  and orderNo != ''"> and vo.order_no = #{orderNo}</if>
            <if test="customerId != null "> and vo.customer_id = #{customerId}</if>
            <if test="productId != null "> and vo.product_id = #{productId}</if>
            <if test="quantity != null "> and vo.quantity = #{quantity}</if>
            <if test="productSnapshot != null  and productSnapshot != ''"> and vo.product_snapshot = #{productSnapshot}</if>
            <if test="totalAmount != null "> and vo.total_amount = #{totalAmount}</if>
            <if test="status != null "> and vo.status = #{status}</if>
            <if test="alipayNo != null  and alipayNo != ''"> and vo.alipay_no = #{alipayNo}</if>
            <if test="payTime != null "> and vo.pay_time = #{payTime}</if>
            <if test="submittedMaterials != null  and submittedMaterials != ''"> and vo.submitted_materials = #{submittedMaterials}</if>
            <if test="auditRemark != null  and auditRemark != ''"> and vo.audit_remark = #{auditRemark}</if>
            <if test="interviewTime != null "> and vo.interview_time = #{interviewTime}</if>
            <if test="interviewLocation != null  and interviewLocation != ''"> and vo.interview_location = #{interviewLocation}</if>
            <if test="interviewFile != null  and interviewFile != ''"> and vo.interview_file = #{interviewFile}</if>
            <if test="interviewFeedback != null "> and vo.interview_feedback = #{interviewFeedback}</if>
            <if test="visaResult != null "> and vo.visa_result = #{visaResult}</if>
            <if test="trackingNumber != null  and trackingNumber != ''"> and vo.tracking_number = #{trackingNumber}</if>
            <if test="mailingAddress != null  and mailingAddress != ''"> and vo.mailing_address = #{mailingAddress}</if>
            <if test="interviewSlots != null  and interviewSlots != ''"> and vo.interview_slots = #{interviewSlots}</if>
            <if test="supplementaryMaterials != null  and supplementaryMaterials != ''"> and vo.supplementary_materials = #{supplementaryMaterials}</if>

            <if test="params.auditType != null and params.auditType == 'processing'">
                AND (vo.status = 4 OR vo.status = 7 OR vo.status = 8)
            </if>
            and vo.del_flag = '0'
        </where>
    </select>
    
    <select id="selectVisaOrderById" parameterType="Long" resultMap="VisaOrderResult">
        <include refid="selectVisaOrderVo"/>
        where vo.id = #{id}
    </select>
    <select id="selectVisaOrderByOrderNo" parameterType="String" resultMap="VisaOrderResult">
        <include refid="selectVisaOrderVo"/>
        where order_no = #{orderNo}
    </select>

    <insert id="insertVisaOrder" parameterType="VisaOrder" useGeneratedKeys="true" keyProperty="id">
        insert into visa_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="quantity != null">quantity,</if>
            <if test="productSnapshot != null">product_snapshot,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            <if test="alipayNo != null">alipay_no,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="submittedMaterials != null">submitted_materials,</if>
            <if test="auditRemark != null">audit_remark,</if>
            <if test="interviewTime != null">interview_time,</if>
            <if test="interviewLocation != null">interview_location,</if>
            <if test="interviewFile != null">interview_file,</if>
            <if test="interviewFeedback != null">interview_feedback,</if>
            <if test="visaResult != null">visa_result,</if>
            <if test="trackingNumber != null">tracking_number,</if>
            <if test="mailingAddress != null">mailing_address,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="interviewSlots != null">interview_slots</if>
            <if test="supplementaryMaterials != null">supplementary_materials</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="productSnapshot != null">#{productSnapshot},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="alipayNo != null">#{alipayNo},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="submittedMaterials != null">#{submittedMaterials},</if>
            <if test="auditRemark != null">#{auditRemark},</if>
            <if test="interviewTime != null">#{interviewTime},</if>
            <if test="interviewLocation != null">#{interviewLocation},</if>
            <if test="interviewFile != null">#{interviewFile},</if>
            <if test="interviewFeedback != null">#{interviewFeedback},</if>
            <if test="visaResult != null">#{visaResult},</if>
            <if test="trackingNumber != null">#{trackingNumber},</if>
            <if test="mailingAddress != null">#{mailingAddress},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="interviewSlots != null">#{interviewSlots},</if>
            <if test="supplementaryMaterials != null">#{supplementaryMaterials},</if>
         </trim>
    </insert>

    <update id="updateVisaOrder" parameterType="VisaOrder">
        update visa_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="productSnapshot != null">product_snapshot = #{productSnapshot},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="alipayNo != null">alipay_no = #{alipayNo},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="submittedMaterials != null">submitted_materials = #{submittedMaterials},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="interviewTime != null">interview_time = #{interviewTime},</if>
            <if test="interviewLocation != null">interview_location = #{interviewLocation},</if>
            <if test="interviewFile != null">interview_file = #{interviewFile},</if>
            <if test="interviewFeedback != null">interview_feedback = #{interviewFeedback},</if>
            <if test="visaResult != null">visa_result = #{visaResult},</if>
            <if test="trackingNumber != null">tracking_number = #{trackingNumber},</if>
            <if test="mailingAddress != null">mailing_address = #{mailingAddress},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="interviewSlots != null">interview_slots = #{interviewSlots},</if>
            <if test="supplementaryMaterials != null">supplementary_materials = #{supplementaryMaterials},</if>
            <if test="isCommented != null">is_commented = #{isCommented},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteVisaOrderById" parameterType="Long">
        delete from visa_order where id = #{id}
    </delete>

    <delete id="deleteVisaOrderByIds" parameterType="String">
        delete from visa_order where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>