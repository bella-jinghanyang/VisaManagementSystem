<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.visa.mapper.VisaOrderLogisticsMapper">
    
    <resultMap type="VisaOrderLogistics" id="VisaOrderLogisticsResult">
        <result property="id"    column="id"    />
        <result property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="direction"    column="direction"    />
        <result property="courierCompany"    column="courier_company"    />
        <result property="trackingNo"    column="tracking_no"    />
        <result property="senderName"    column="sender_name"    />
        <result property="senderPhone"    column="sender_phone"    />
        <result property="mailAddress"    column="mail_address"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="receiveTime"    column="receive_time"    />
    </resultMap>

    <sql id="selectVisaOrderLogisticsVo">
        select id, order_id, order_no, direction, courier_company, tracking_no, sender_name, sender_phone, mail_address, status, create_time, receive_time from visa_order_logistics
    </sql>

    <select id="selectVisaOrderLogisticsList" parameterType="VisaOrderLogistics" resultMap="VisaOrderLogisticsResult">
        <include refid="selectVisaOrderLogisticsVo"/>
        <where>  
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="direction != null "> and direction = #{direction}</if>
            <if test="courierCompany != null  and courierCompany != ''"> and courier_company = #{courierCompany}</if>
            <if test="trackingNo != null  and trackingNo != ''"> and tracking_no = #{trackingNo}</if>
            <if test="senderName != null  and senderName != ''"> and sender_name like concat('%', #{senderName}, '%')</if>
            <if test="senderPhone != null  and senderPhone != ''"> and sender_phone = #{senderPhone}</if>
            <if test="mailAddress != null  and mailAddress != ''"> and mail_address = #{mailAddress}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="receiveTime != null "> and receive_time = #{receiveTime}</if>
        </where>
    </select>
    
    <select id="selectVisaOrderLogisticsById" parameterType="Long" resultMap="VisaOrderLogisticsResult">
        <include refid="selectVisaOrderLogisticsVo"/>
        where id = #{id}
    </select>

    <insert id="insertVisaOrderLogistics" parameterType="VisaOrderLogistics" useGeneratedKeys="true" keyProperty="id">
        insert into visa_order_logistics
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null">order_id,</if>
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="direction != null">direction,</if>
            <if test="courierCompany != null">courier_company,</if>
            <if test="trackingNo != null">tracking_no,</if>
            <if test="senderName != null">sender_name,</if>
            <if test="senderPhone != null">sender_phone,</if>
            <if test="mailAddress != null">mail_address,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="receiveTime != null">receive_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null">#{orderId},</if>
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="direction != null">#{direction},</if>
            <if test="courierCompany != null">#{courierCompany},</if>
            <if test="trackingNo != null">#{trackingNo},</if>
            <if test="senderName != null">#{senderName},</if>
            <if test="senderPhone != null">#{senderPhone},</if>
            <if test="mailAddress != null">#{mailAddress},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="receiveTime != null">#{receiveTime},</if>
         </trim>
    </insert>

    <update id="updateVisaOrderLogistics" parameterType="VisaOrderLogistics">
        update visa_order_logistics
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="direction != null">direction = #{direction},</if>
            <if test="courierCompany != null">courier_company = #{courierCompany},</if>
            <if test="trackingNo != null">tracking_no = #{trackingNo},</if>
            <if test="senderName != null">sender_name = #{senderName},</if>
            <if test="senderPhone != null">sender_phone = #{senderPhone},</if>
            <if test="mailAddress != null">mail_address = #{mailAddress},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="receiveTime != null">receive_time = #{receiveTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteVisaOrderLogisticsById" parameterType="Long">
        delete from visa_order_logistics where id = #{id}
    </delete>

    <delete id="deleteVisaOrderLogisticsByIds" parameterType="String">
        delete from visa_order_logistics where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>