<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.visa.mapper.VisaKnowledgeMapper">

    <resultMap type="VisaKnowledge" id="VisaKnowledgeResult">
        <result property="id"          column="id"          />
        <result property="category"    column="category"    />
        <result property="title"       column="title"       />
        <result property="keywords"    column="keywords"    />
        <result property="content"     column="content"     />
        <result property="status"      column="status"      />
        <result property="embedding"   column="embedding"   />
        <result property="sourceFile"  column="source_file" />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <sql id="selectVisaKnowledgeVo">
        select id, category, title, keywords, content, status, create_time, embedding, source_file from visa_knowledge
    </sql>

    <select id="selectVisaKnowledgeList" parameterType="VisaKnowledge" resultMap="VisaKnowledgeResult">
        <include refid="selectVisaKnowledgeVo"/>
        <where>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="keywords != null  and keywords != ''">
                and (keywords LIKE CONCAT('%', #{keywords}, '%')
                OR title    LIKE CONCAT('%', #{keywords}, '%')
                OR content  LIKE CONCAT('%', #{keywords}, '%'))
            </if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>

    <select id="selectVisaKnowledgeById" parameterType="Long" resultMap="VisaKnowledgeResult">
        <include refid="selectVisaKnowledgeVo"/>
        where id = #{id}
    </select>

    <!-- RAG 专用：拉取全部有效条目，包含 embedding 字段 -->
    <select id="selectAllActiveWithEmbedding" resultMap="VisaKnowledgeResult">
        select id, category, title, keywords, content, status, embedding, create_time
        from visa_knowledge
        where status = '0'
    </select>

    <insert id="insertVisaKnowledge" parameterType="VisaKnowledge" useGeneratedKeys="true" keyProperty="id">
        insert into visa_knowledge
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="category != null">category,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="keywords != null">keywords,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="status != null">status,</if>
            <if test="sourceFile != null">source_file,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="category != null">#{category},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="status != null">#{status},</if>
            <if test="sourceFile != null">#{sourceFile},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateVisaKnowledge" parameterType="VisaKnowledge">
        update visa_knowledge
        <trim prefix="SET" suffixOverrides=",">
            <if test="category != null">category = #{category},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sourceFile != null">source_file = #{sourceFile},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <!-- 仅更新向量字段，避免全字段覆盖 -->
    <update id="updateEmbeddingById">
        update visa_knowledge set embedding = #{embedding} where id = #{id}
    </update>

    <delete id="deleteVisaKnowledgeById" parameterType="Long">
        delete from visa_knowledge where id = #{id}
    </delete>

    <delete id="deleteVisaKnowledgeByIds" parameterType="String">
        delete from visa_knowledge where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>