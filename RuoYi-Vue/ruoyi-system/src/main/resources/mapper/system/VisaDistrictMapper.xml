<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.visa.mapper.VisaDistrictMapper">
    
    <resultMap type="VisaDistrict" id="VisaDistrictResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="coverArea"    column="cover_area"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectVisaDistrictVo">
        select id, name, cover_area, sort, status from visa_district
    </sql>

    <select id="selectVisaDistrictList" parameterType="VisaDistrict" resultMap="VisaDistrictResult">
        <include refid="selectVisaDistrictVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="coverArea != null  and coverArea != ''"> and cover_area = #{coverArea}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectVisaDistrictById" parameterType="Long" resultMap="VisaDistrictResult">
        <include refid="selectVisaDistrictVo"/>
        where id = #{id}
    </select>

    <insert id="insertVisaDistrict" parameterType="VisaDistrict" useGeneratedKeys="true" keyProperty="id">
        insert into visa_district
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="coverArea != null">cover_area,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="coverArea != null">#{coverArea},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
         </trim>
    </insert>

    <update id="updateVisaDistrict" parameterType="VisaDistrict">
        update visa_district
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="coverArea != null">cover_area = #{coverArea},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where id = #{id}
    </update>
    <update id="updateDistrictStatus">
        update visa_district
        set status = #{status}
        where id = #{id}
    </update>

    <delete id="deleteVisaDistrictById" parameterType="Long">
        delete from visa_district where id = #{id}
    </delete>

    <delete id="deleteVisaDistrictByIds" parameterType="String">
        delete from visa_district where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>